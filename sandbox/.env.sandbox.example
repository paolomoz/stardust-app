# Copy to .env.sandbox and fill in. Used by poll.sh.
# From `node agent/setup.mjs --self-hosted` (environment id) and the Console
# step "Generate environment key" (the oat key).
ANTHROPIC_ENVIRONMENT_ID=env_...
ANTHROPIC_ENVIRONMENT_KEY=sk-ant-oat01-...
# Optional overrides:
# IMAGE=stardust-sandbox
# OUTPUTS_DIR=/abs/path/to/outputs
